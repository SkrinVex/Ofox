<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Ofox" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Тема для редактора стикеров — тёмная с оранжевым акцентом -->
    <style name="Theme.Ofox.Editor" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorPrimary">#FF6B35</item>
        <item name="android:colorAccent">#FF6B35</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
        <item name="colorPrimary">#FF6B35</item>
        <item name="colorAccent">#FF6B35</item>
        <!-- Стиль диалогов -->
        <item name="android:alertDialogTheme">@style/Theme.Ofox.Dialog</item>
        <item name="alertDialogTheme">@style/Theme.Ofox.Dialog</item>
    </style>

    <style name="Theme.Ofox.Dialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:background">#1E1E1E</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="colorAccent">#FF6B35</item>
        <item name="colorPrimary">#FF6B35</item>
        <item name="buttonBarPositiveButtonStyle">@style/Theme.Ofox.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Theme.Ofox.Button.Negative</item>
    </style>

    <style name="Theme.Ofox.Button.Positive" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#FF6B35</item>
    </style>

    <style name="Theme.Ofox.Button.Negative" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#AAAAAA</item>
    </style>
</resources>
